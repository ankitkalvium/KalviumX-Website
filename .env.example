# Copy to .env.local and fill in. Never commit real values.

# Ticker pipeline (Gemini)
GEMINI_API_KEY=

# Vercel Cron auth for /api/cron/ticker — Vercel sends this as
# `Authorization: Bearer <value>` on cron-triggered requests. Optional, but
# strongly recommended: without it the route is publicly callable.
CRON_SECRET=

# Zoho CRM — lead upsert with dedup (India data center)
# Generate via api-console.zoho.com → Self Client → scope must include
# ZohoCRM.modules.leads.READ,ZohoCRM.modules.leads.CREATE,ZohoCRM.modules.leads.UPDATE
# (CREATE-only breaks dedup — search/get-by-id calls 401 and silently look like "no match")
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.in
ZOHO_API_DOMAIN=https://www.zohoapis.in

# Optional secondary lead webhook (Slack / Brevo / Zapier)
LEAD_WEBHOOK_URL=

# Cal.com webhook signature secret (optional — skips verification if unset)
# Generate in Cal.com → Settings → Developer → Webhooks → Secret
CAL_WEBHOOK_SECRET=

# Conversational hiring intake
DATABASE_URL=

# Auth.js Google OAuth for the @kalvium.com admin dashboard
# Callback URL: http://localhost:3000/api/auth/callback/google
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Sanity CMS — blog content (/blog, editable at /studio)
# Create a free project at sanity.io/manage, then `npx sanity@latest login`
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Shared secret checked against the Apps Script trigger that pushes the
# student tracker Google Sheet into the Students pool in real time.
STUDENT_SHEET_SYNC_SECRET=
